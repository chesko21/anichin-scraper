{
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/populer",
      "destination": "/"
    },
    {
      "source": "/schedule",
      "destination": "/"
    }
  ],
  "redirects": [
    {
      "source": "/old-path/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/refresh-cache",
      "schedule": "0 */6 * * *"
    }
  ]
}